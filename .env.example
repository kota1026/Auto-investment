# Anthropic Claude API (AI signal confirmer)
ANTHROPIC_API_KEY=sk-ant-...

# Exchange (Binance testnet by default — never put real keys here)
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_TESTNET=true

# Trading parameters
SYMBOL=BTC/USDT
TIMEFRAME=1h
EQUITY_USD=10000
RISK_PER_TRADE=0.01

# AI gating
AI_ENABLED=true
AI_MODEL=claude-opus-4-6
AI_MIN_CONFIDENCE=0.6

# Server
HOST=127.0.0.1
PORT=8000
