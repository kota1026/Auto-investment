# Anthropic Claude API (AI signal confirmer)
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional context providers (all gracefully skipped if unset) ---
# Tavily — news search & sentiment for the AI advisor (https://tavily.com)
TAVILY_API_KEY=
# FRED — Federal Reserve macro data (free key at fred.stlouisfed.org)
FRED_API_KEY=
# Novaquity — Japanese alt-data (https://novaquity.net) — only used when SYMBOL is a 4-digit TSE code
NOVAQUITY_API_KEY=
NOVAQUITY_BASE_URL=https://api.novaquity.net/v1

# Exchange (Binance testnet by default — never put real keys here)
# Supported: binance, bybit, okx, kraken, hyperliquid, coinbase, ...
# For Hyperliquid (DEX): set EXCHANGE_ID=hyperliquid and put your wallet
# private key in EXCHANGE_API_SECRET (no 0x prefix). Leave EXCHANGE_API_KEY blank.
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_TESTNET=true

# Trading parameters
SYMBOL=BTC/USDT
TIMEFRAME=1h
EQUITY_USD=10000
RISK_PER_TRADE=0.01

# AI gating
AI_ENABLED=true
AI_MODEL=claude-opus-4-6
AI_MIN_CONFIDENCE=0.6

# Server
HOST=127.0.0.1
PORT=8000
